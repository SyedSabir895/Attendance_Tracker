NODE_ENV=development
PORT=5000

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/attendance_system?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_long
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_chars
JWT_REFRESH_EXPIRE=30d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@attendancesystem.com
FROM_NAME=Attendance System

CLIENT_URL=http://localhost:5173

MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
